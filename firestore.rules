rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Collections ---

    // Users
    match /users/{userId} {
      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() <= 100 &&
               data.email is string && data.email.size() <= 100;
      }
      
      allow get: if isSignedIn();
      allow list: if isSignedIn(); // Allow searching users for ranking
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'bio', 'stats'])
      );
    }

    // Rides
    match /rides/{rideId} {
      function isValidRide(data) {
        return data.title is string && data.title.size() <= 100 &&
               data.creatorId == request.auth.uid &&
               data.distance is number &&
               data.level in ['Iniciante', 'Intermediário', 'Avançado'];
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidRide(incoming()) && incoming().createdAt == request.time;
      allow update: if isSignedIn() && (
        // Creator can edit everything
        (isOwner(existing().creatorId) && isValidRide(incoming())) ||
        // Others can only update participantCount (simulated, better to use subcollection)
        (incoming().diff(existing()).affectedKeys().hasOnly(['participantCount']))
      );
      allow delete: if isSignedIn() && isOwner(existing().creatorId);

      match /participants/{userId} {
        allow read: if isSignedIn();
        allow write: if isOwner(userId);
      }
    }

    // Workouts
    match /workouts/{workoutId} {
      function isValidWorkout(data) {
        return data.userId == request.auth.uid &&
               data.distance is number &&
               data.duration is number;
      }

      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isValidWorkout(incoming()) && incoming().createdAt == request.time;
      allow update: if isOwner(existing().userId) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name'])
      );
      allow delete: if isOwner(existing().userId);
    }
  }
}
