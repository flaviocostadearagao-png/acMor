rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Master Gate / Deny All
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collections ---

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming());
      
      function isValidUser(data) {
        return data.keys().hasAll(['displayName', 'email'])
          && data.displayName is string && data.displayName.size() <= 100
          && data.email is string && data.email.size() <= 100;
      }
    }

    // WORKOUTS
    match /workouts/{workoutId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isOwner(incoming().userId));
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && isOwner(incoming().userId) && isValidWorkout(incoming());
      allow update: if isSignedIn() && isOwner(existing().userId) && isValidWorkout(incoming());
      allow delete: if isSignedIn() && isOwner(existing().userId);

      function isValidWorkout(data) {
        return data.userId == request.auth.uid
          && data.distance is number
          && data.duration is number
          && data.path is list;
      }
    }

    // RIDES
    match /rides/{rideId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isOwner(incoming().creatorId) && isValidRide(incoming());
      allow update: if isSignedIn() && (
        isOwner(existing().creatorId) || 
        (incoming().diff(existing()).affectedKeys().hasOnly(['participantCount']))
      );
      allow delete: if isSignedIn() && isOwner(existing().creatorId);

      function isValidRide(data) {
        return data.creatorId == request.auth.uid
          && data.title is string && data.title.size() <= 200
          && data.participantCount is number;
      }

      // PARTICIPANTS
      match /participants/{participantId} {
        allow read: if isSignedIn();
        allow create: if isOwner(participantId) && isValidParticipant(incoming());
        allow delete: if isOwner(participantId);

        function isValidParticipant(data) {
          return data.userId == request.auth.uid;
        }
      }
    }
  }
}
