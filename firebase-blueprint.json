{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and statistics",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "bio": { "type": "string" },
        "stats": {
          "type": "object",
          "properties": {
            "totalDistance": { "type": "number" },
            "totalRides": { "type": "number" },
            "points": { "type": "number" },
            "monthlyDistance": { "type": "number" },
            "lastMonthUpdated": { "type": "string" }
          }
        },
        "records": {
          "type": "object",
          "properties": {
            "longestRide": { "type": "number" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["displayName", "email"]
    },
    "Workout": {
      "title": "Workout",
      "description": "Recorded cycling session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "distance": { "type": "number" },
        "duration": { "type": "number" },
        "avgSpeed": { "type": "number" },
        "path": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "distance", "duration", "path"]
    },
    "Ride": {
      "title": "Ride",
      "description": "Community cycling event",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "level": { "type": "string" },
        "distance": { "type": "number" },
        "startTime": { "type": "string" },
        "address": { "type": "string" },
        "creatorId": { "type": "string" },
        "creatorName": { "type": "string" },
        "participantCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "creatorId", "startTime"]
    },
    "Participant": {
      "title": "Participant",
      "description": "User participating in a ride",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "joinedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Cycling workouts"
    },
    "rides/{rideId}": {
      "schema": "Ride",
      "description": "Community rides"
    },
    "rides/{rideId}/participants/{userId}": {
      "schema": "Participant",
      "description": "Ride participants"
    }
  }
}
